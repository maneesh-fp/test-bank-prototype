# Fingerprint Server API Key (v3 + v4)
FP_SERVER_API_KEY=your_server_api_key_here

# Webhook secrets
FP_WEBHOOK_SECRET=your_v3_webhook_secret_here
FP_WEBHOOK_SECRET_V4=your_v4_webhook_secret_here

# Sealed results decryption keys (base64-encoded AES-256-GCM)
FP_SEALED_KEY=your_v3_sealed_key_here
FP_SEALED_KEY_ACCOUNTS=your_v4_sealed_key_here

# JS Agent public API keys (v3 login, v4 accounts/dashboard)
FP_JS_AGENT_KEY_V3=your_v3_js_agent_public_key
FP_JS_AGENT_KEY_V4=your_v4_js_agent_public_key

# Custom proxy endpoint (v3 login page) — leave blank to use default Fingerprint CDN
FP_PROXY_ENDPOINT=
FP_PROXY_SCRIPT=
